  UserVoucher [shape=box, fillcolor="#b6f2b6", label="UserVouchers", pos="1560,160!" ];
  Voucher [shape=box, fillcolor="#b6f2b6", label="Vouchers", pos="1560,80!" ];

  // RELATIONSHIPS (diamond)
  R_User_Order [shape=diamond, fillcolor="#ffe4b3", label="Dat hang", pos="1040,200!" ];
  R_User_Order -> Users [xlabel="1"];
  R_User_Order -> Order [xlabel="0..N"];

