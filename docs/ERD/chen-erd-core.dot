digraph ERD {
  rankdir=TB;
  bgcolor="white";
  pad=0.25;
  margin=0.15;
  outputorder="edgesfirst";
  graph [layout=neato, overlap=false, splines=true, fontname="Arial"];
  fontname="Arial"; fontsize=10;
  node [fontname="Arial", fontsize=10];
  edge [fontname="Arial", fontsize=9];

  // Style palette similar to Chen examples
  node [style="filled"];
  edge [color="#555555"];

  // ENTITIES (rectangle)
  Category [shape=box, fillcolor="#b6f2b6", label="Categories", pos="0,200!" ];
  Product [shape=box, fillcolor="#b6f2b6", label="Products", pos="0,120!" ];
  ProductImage [shape=box, fillcolor="#b6f2b6", label="ProductImages", pos="0,40!" ];
