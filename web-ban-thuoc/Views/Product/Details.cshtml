@using System.Text.Json
@model web_ban_thuoc.Models.Product

@*
    Trang chi tiết sản phẩm - Giao diện tối ưu lại
*@
@{
    ViewData["Title"] = "Chi tiết sản phẩm - Nhà Thuốc Long Châu";
}
@{
    var userReview = ViewBag.UserReview as web_ban_thuoc.Models.Review;
    bool canReview = ViewBag.CanReview == true;
    var avgRating = Model.Reviews.Any() ? Math.Round(Model.Reviews.Average(r => r.Rating ?? 0), 1) : 0;
    var reviewCount = Model.Reviews.Count();
    var inStock = Model.StockQuantity > 0;
    var hasIngredients = !string.IsNullOrEmpty(Model.Ingredients);
    var hasUses = !string.IsNullOrWhiteSpace(Model.Uses);
    var hasDosage = !string.IsNullOrWhiteSpace(Model.Dosage);
    var hasTarget = !string.IsNullOrWhiteSpace(Model.TargetUsers);
    var hasContra = !string.IsNullOrWhiteSpace(Model.Contraindications);
    var hasGuideTab = hasDosage || hasTarget;
    var hasDetailTab = hasIngredients || hasUses || hasContra;
}
<div class="pb-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-4 small bg-white px-3 py-2 rounded-3 shadow-sm">
            <li class="breadcrumb-item">
                <a href="/" class="text-decoration-none text-secondary">Trang Chủ</a>
            </li>
            <li class="breadcrumb-item">
                <a href="/Categories/@Model.Category?.CategoryId"
                    class="text-decoration-none text-secondary">@Model.Category?.CategoryName</a>
            </li>
            <li class="breadcrumb-item active text-primary" aria-current="page">@Model.ProductName</li>
        </ol>
    </nav>
    <!-- Container chung cho cả hai phần -->
    <div class="product-container bg-white rounded-4 shadow-lg p-4">
        <div class="row g-4 align-items-start">
            <!-- Slider ảnh (Sticky) -->
            <div class="col-12 col-lg-5 sticky-top" style="top: 20px; max-height: 100vh; overflow-y: auto;">
                <div class="bg-white rounded-4 shadow-sm p-4 h-100 d-flex flex-column align-items-center">
                    <div class="w-100 mb-3">
                        <img id="mainImage"
                            src="/images/products/@(Model.ProductImages?.FirstOrDefault(i => i.IsMain == true)?.ImageUrl ?? Model.ProductImages?.FirstOrDefault()?.ImageUrl ?? "/images/products/vitamin_vien_sui_kudos_do.png")"
                            alt="Main Product Image" class="img-fluid rounded-4 shadow w-100"
                            style="max-height: 320px; object-fit: contain; background: #f8fafc;" />
                    </div>
                    <div class="horizontal-slider position-relative w-100 mt-2">
                        <button
                            class="btn btn-light btn-sm rounded-circle position-absolute top-50 translate-middle-y shadow"
                            onclick="moveUp()" style="z-index: 10; left: -12px;">
                            <i class="fas fa-chevron-left"></i>
                        </button>
                        <div class="slider-wrapper d-flex align-items-center overflow-hidden"
                            style="height: 70px; width: 444px; place-self: anchor-center;">
                            <div id="sliderImages" class="slider-images d-flex flex-row transition-transform"
                                style="transform: translateX(0px);">
                                @foreach (var image in Model.ProductImages ?? Enumerable.Empty<ProductImage>())
                                {
                                    <img src="/images/products/@image.ImageUrl" alt="Image" width="60" height="60"
                                        class="border bg-white shadow-sm rounded-3 cursor-pointer mx-2 @(image.IsMain == true ? "selected-item-slider" : "")"
                                        onclick="imageClicked('/images/products/@image.ImageUrl')"
                                        style="object-fit:cover;transition:box-shadow .2s;" />
                                }
                            </div>
                        </div>
                        <button
                            class="btn btn-light btn-sm rounded-circle position-absolute top-50 translate-middle-y shadow"
                            onclick="moveDown()" style="z-index: 10; right: -12px;">
                            <i class="fas fa-chevron-right"></i>
                        </button>
                    </div>
                </div>
            </div>
            <!-- Thông tin sản phẩm -->
            <div class="col-12 col-lg-7">
                <div class="pd-aside">
                    <header class="pd-header">
                        @if (!string.IsNullOrEmpty(Model.Brand))
                        {
                            <div class="pd-brand">@Model.Brand</div>
                        }
                        <h1 class="pd-title">@Model.ProductName</h1>
                        <div class="pd-rating-row">
                            <div class="pd-stars" aria-label="Đánh giá @avgRating trên 5">
                                @for (int s = 1; s <= 5; s++)
                                {
                                    <i class="fa@(s <= Math.Round(avgRating) ? "s" : "r") fa-star"></i>
                                }
                            </div>
                            <span class="pd-rating-text">@avgRating</span>
                            <a href="#reviews-section" class="pd-review-link">@reviewCount đánh giá</a>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.Sku))
                        {
                            <div class="pd-sku">SKU: @Model.Sku</div>
                        }
                    </header>

                    <div class="pd-purchase-card">
                        <div class="pd-purchase-top">
                            <div>
                                <div id="main-product-price" class="pd-price">@Model.Price.ToString("N0")<small>đ</small></div>
                                @if (!string.IsNullOrEmpty(Model.Package))
                                {
                                    <div class="pd-package">@Model.Package</div>
                                }
                            </div>
                            <div class="pd-badges">
                                @if (Model.RequiresPrescription)
                                {
                                    <span class="pd-badge pd-badge-rx"><i class="fa fa-prescription me-1"></i>Cần toa</span>
                                }
                                else
                                {
                                    <span class="pd-badge pd-badge-otc">OTC</span>
                                }
                                <span class="pd-badge @(inStock ? "pd-badge-in" : "pd-badge-out")">
                                    <span class="pd-status-dot"></span>@(inStock ? "Còn hàng" : "Tạm hết hàng")
                                </span>
                            </div>
                        </div>

                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="pd-cart-form">
                            <input type="hidden" name="productId" value="@Model.ProductId" />
                            <div class="pd-cart-row">
                                <div class="pd-qty" @(inStock ? "" : "data-disabled")>
                                    <button type="button" class="pd-qty-btn" onclick="decreaseQuantity()" @(inStock ? "" : "disabled") aria-label="Giảm"><i class="fas fa-minus"></i></button>
                                    <input type="number" id="quantity" name="quantity" value="1" min="1" max="@Model.StockQuantity" readonly aria-label="Số lượng" />
                                    <button type="button" class="pd-qty-btn" onclick="increaseQuantity()" @(inStock ? "" : "disabled") aria-label="Tăng"><i class="fas fa-plus"></i></button>
                                </div>
                                <button type="submit" class="pd-btn-cart" @(inStock ? "" : "disabled")>
                                    <i class="fas fa-cart-plus"></i>
                                    <span>@(inStock ? "Thêm vào giỏ" : "Tạm hết hàng")</span>
                                </button>
                            </div>
                        </form>
                        <button id="ask-product-btn" type="button" class="pd-btn-ask">
                            <i class="fa-regular fa-circle-question"></i> Hỏi tư vấn về sản phẩm
                        </button>
                    </div>

                    <div class="pd-specs">
                        @if (Model.Category != null)
                        {
                            <div class="pd-spec-item">
                                <i class="fa fa-tags"></i>
                                <div><span>Danh mục</span><strong><a href="/Categories/@Model.Category.CategoryId">@Model.Category.CategoryName</a></strong></div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Origin))
                        {
                            <div class="pd-spec-item">
                                <i class="fa fa-globe"></i>
                                <div><span>Xuất xứ</span><strong>@Model.Origin</strong></div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.RegistrationNumber))
                        {
                            <div class="pd-spec-item">
                                <i class="fa fa-certificate"></i>
                                <div><span>Số ĐK BYT</span><strong>@Model.RegistrationNumber</strong></div>
                            </div>
                        }
                    </div>

                    @if (hasDetailTab || hasGuideTab)
                    {
                        <div class="pd-tabs-wrap">
                            <ul class="nav nav-pills pd-tabs" role="tablist">
                                @if (hasUses || hasIngredients)
                                {
                                    <li class="nav-item"><button class="nav-link active" data-bs-toggle="pill" data-bs-target="#pd-tab-desc" type="button">Mô tả</button></li>
                                }
                                @if (hasGuideTab)
                                {
                                    <li class="nav-item"><button class="nav-link @(!(hasUses || hasIngredients) ? "active" : "")" data-bs-toggle="pill" data-bs-target="#pd-tab-guide" type="button">Hướng dẫn</button></li>
                                }
                                @if (hasContra)
                                {
                                    <li class="nav-item"><button class="nav-link @(!(hasUses || hasIngredients) && !hasGuideTab ? "active" : "")" data-bs-toggle="pill" data-bs-target="#pd-tab-warn" type="button">Lưu ý</button></li>
                                }
                            </ul>
                            <div class="tab-content pd-tab-content">
                                @if (hasUses || hasIngredients)
                                {
                                    <div class="tab-pane fade show active" id="pd-tab-desc">
                                        @if (hasUses)
                                        {
                                            <div class="pd-content-block">
                                                <h6><i class="fa fa-heart-pulse me-2"></i>Công dụng</h6>
                                                <p>@Model.Uses</p>
                                            </div>
                                        }
                                        @if (hasIngredients)
                                        {
                                            var ingredients = JsonSerializer.Deserialize<List<Dictionary<string, string>>>(Model.Ingredients!);
                                            <div class="pd-content-block">
                                                <h6><i class="fa fa-flask me-2"></i>Thành phần @(string.IsNullOrEmpty(Model.IngredientUnit) ? "" : $"({Model.IngredientUnit})")</h6>
                                                <div class="pd-ingredient-table">
                                                    @foreach (var ing in ingredients ?? new List<Dictionary<string, string>>())
                                                    {
                                                        <div class="pd-ingredient-row">
                                                            <span>@ing.GetValueOrDefault("name", "")</span>
                                                            <span>@ing.GetValueOrDefault("amount", "")</span>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                @if (hasGuideTab)
                                {
                                    <div class="tab-pane fade @(!(hasUses || hasIngredients) ? "show active" : "")" id="pd-tab-guide">
                                        @if (hasDosage)
                                        {
                                            <div class="pd-content-block">
                                                <h6><i class="fa fa-pills me-2"></i>Liều dùng / Cách dùng</h6>
                                                <p>@Model.Dosage</p>
                                            </div>
                                        }
                                        @if (hasTarget)
                                        {
                                            <div class="pd-content-block">
                                                <h6><i class="fa fa-users me-2"></i>Đối tượng sử dụng</h6>
                                                <p>@Model.TargetUsers</p>
                                            </div>
                                        }
                                    </div>
                                }
                                @if (hasContra)
                                {
                                    <div class="tab-pane fade @(!(hasUses || hasIngredients) && !hasGuideTab ? "show active" : "")" id="pd-tab-warn">
                                        <div class="pd-content-block pd-content-warn">
                                            <h6><i class="fa fa-triangle-exclamation me-2"></i>Chống chỉ định</h6>
                                            <p>@Model.Contraindications</p>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <div class="pd-notice">
                        <i class="fa fa-shield-halved"></i>
                        <div>
                            <strong>Lưu ý an toàn</strong>
                            <p>Sản phẩm không phải thuốc, không thay thế thuốc chữa bệnh. Đọc kỹ hướng dẫn trước khi dùng. Ngừng sử dụng nếu có phản ứng bất thường.</p>
                        </div>
                    </div>

                    <div class="pd-trust">
                        <div class="pd-trust-item"><i class="fa fa-rotate-left"></i><span>Đổi trả 30 ngày</span></div>
                        <div class="pd-trust-item"><i class="fa fa-pills"></i><span>Đổi thuốc miễn phí</span></div>
                        <div class="pd-trust-item"><i class="fa fa-truck"></i><span>Giao hàng toàn quốc</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background: #f4f7fb;
    }

    .selected-item-slider {
        border-color: #2563eb !important;
        box-shadow: 0 0 0 2px #60a5fa33;
    }

    .transition-transform {
        transition: transform 0.4s cubic-bezier(.4, 2, .6, 1);
    }

    .btn-gradient {
        background: linear-gradient(90deg, #3b82f6 0%, #60a5fa 100%);
        color: #fff;
        border: none;
    }

    .btn-gradient:hover {
        background: linear-gradient(90deg, #2563eb 0%, #3b82f6 100%);
        color: #fff;
    }

    .text-gradient {
        background: linear-gradient(90deg, #3b82f6, #60a5fa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    /* —— Product detail aside —— */
    .pd-aside { display: flex; flex-direction: column; gap: 1.25rem; }

    .pd-brand {
        font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em;
        text-transform: uppercase; color: #1976d2; margin-bottom: 0.4rem;
    }
    .pd-title {
        font-size: 1.4rem; font-weight: 700; color: #0f172a;
        line-height: 1.45; margin: 0 0 0.65rem;
    }
    .pd-rating-row {
        display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.35rem;
    }
    .pd-stars { color: #f59e0b; font-size: 0.85rem; letter-spacing: 1px; }
    .pd-rating-text { font-weight: 700; color: #334155; font-size: 0.9rem; }
    .pd-review-link { font-size: 0.85rem; color: #1976d2; text-decoration: none; }
    .pd-review-link:hover { text-decoration: underline; }
    .pd-sku { font-size: 0.8rem; color: #94a3b8; font-family: ui-monospace, monospace; }

    .pd-purchase-card {
        background: linear-gradient(135deg, #f8fbff 0%, #fff 100%);
        border: 1px solid #dbeafe; border-radius: 1rem;
        padding: 1.25rem; box-shadow: 0 4px 20px rgba(25, 118, 210, 0.08);
    }
    .pd-purchase-top {
        display: flex; justify-content: space-between; align-items: flex-start;
        gap: 1rem; margin-bottom: 1.1rem;
    }
    .pd-price {
        font-size: 2rem; font-weight: 800; color: #1565c0; line-height: 1.1;
    }
    .pd-price small { font-size: 1.1rem; font-weight: 600; margin-left: 2px; }
    .pd-package { font-size: 0.85rem; color: #64748b; margin-top: 0.2rem; }
    .pd-badges { display: flex; flex-direction: column; gap: 0.35rem; align-items: flex-end; }
    .pd-badge {
        font-size: 0.72rem; font-weight: 600; padding: 0.25rem 0.6rem;
        border-radius: 2rem; white-space: nowrap;
    }
    .pd-badge-rx { background: #fef3c7; color: #92400e; }
    .pd-badge-otc { background: #ecfdf5; color: #047857; }
    .pd-badge-in { background: #eff6ff; color: #1d4ed8; display: flex; align-items: center; gap: 0.35rem; }
    .pd-badge-out { background: #fef2f2; color: #b91c1c; display: flex; align-items: center; gap: 0.35rem; }
    .pd-status-dot {
        width: 7px; height: 7px; border-radius: 50%; background: currentColor;
    }
    .pd-badge-in .pd-status-dot { background: #22c55e; }
    .pd-badge-out .pd-status-dot { background: #ef4444; }

    .pd-cart-row { display: flex; gap: 0.75rem; }
    .pd-qty {
        display: flex; align-items: center; background: #fff;
        border: 1px solid #e2e8f0; border-radius: 0.65rem; overflow: hidden;
    }
    .pd-qty[data-disabled] { opacity: 0.5; }
    .pd-qty input {
        width: 42px; border: none; text-align: center; font-weight: 600;
        font-size: 1rem; background: transparent; color: #1e293b;
    }
    .pd-qty-btn {
        border: none; background: transparent; padding: 0.6rem 0.75rem;
        color: #475569; cursor: pointer; transition: background 0.15s;
    }
    .pd-qty-btn:hover:not(:disabled) { background: #f1f5f9; }
    .pd-qty-btn:disabled { cursor: not-allowed; opacity: 0.4; }
    .pd-btn-cart {
        flex: 1; border: none; border-radius: 0.65rem;
        background: linear-gradient(135deg, #1976d2, #1565c0);
        color: #fff; font-weight: 700; font-size: 0.95rem;
        display: flex; align-items: center; justify-content: center; gap: 0.5rem;
        padding: 0.7rem 1rem; transition: transform 0.15s, box-shadow 0.15s;
        box-shadow: 0 4px 14px rgba(25, 118, 210, 0.35);
    }
    .pd-btn-cart:hover:not(:disabled) { transform: translateY(-1px); box-shadow: 0 6px 18px rgba(25, 118, 210, 0.4); }
    .pd-btn-cart:disabled { background: #cbd5e1; box-shadow: none; cursor: not-allowed; }
    .pd-btn-ask {
        width: 100%; margin-top: 0.75rem; border: 1px dashed #93c5fd;
        background: transparent; color: #1976d2; border-radius: 0.65rem;
        padding: 0.55rem; font-size: 0.85rem; font-weight: 500;
        display: flex; align-items: center; justify-content: center; gap: 0.4rem;
        transition: background 0.15s;
    }
    .pd-btn-ask:hover { background: #eff6ff; }

    .pd-specs {
        display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 0.65rem;
    }
    .pd-spec-item {
        display: flex; align-items: flex-start; gap: 0.65rem;
        padding: 0.75rem; background: #f8fafc; border-radius: 0.65rem;
        border: 1px solid #f1f5f9;
    }
    .pd-spec-item i { color: #1976d2; margin-top: 2px; font-size: 0.9rem; }
    .pd-spec-item span { display: block; font-size: 0.72rem; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.03em; }
    .pd-spec-item strong { font-size: 0.85rem; color: #1e293b; font-weight: 600; }
    .pd-spec-item a { color: #1976d2; text-decoration: none; }
    .pd-spec-item a:hover { text-decoration: underline; }

    .pd-tabs-wrap { background: #fff; border: 1px solid #e2e8f0; border-radius: 0.85rem; overflow: hidden; }
    .pd-tabs {
        padding: 0.65rem 0.65rem 0; gap: 0.35rem; background: #f8fafc;
        border-bottom: 1px solid #e2e8f0; flex-wrap: nowrap; overflow-x: auto;
    }
    .pd-tabs .nav-link {
        font-size: 0.85rem; font-weight: 600; color: #64748b;
        border-radius: 0.5rem 0.5rem 0 0; padding: 0.5rem 1rem;
        white-space: nowrap; border: none;
    }
    .pd-tabs .nav-link.active { background: #fff; color: #1976d2; box-shadow: 0 -2px 0 #1976d2 inset; }
    .pd-tab-content { padding: 1rem 1.15rem; }
    .pd-content-block { margin-bottom: 1rem; }
    .pd-content-block:last-child { margin-bottom: 0; }
    .pd-content-block h6 { font-size: 0.9rem; font-weight: 700; color: #334155; margin-bottom: 0.5rem; }
    .pd-content-block p { font-size: 0.9rem; color: #475569; line-height: 1.7; margin: 0; white-space: pre-line; }
    .pd-content-warn h6 { color: #b45309; }
    .pd-ingredient-table { border: 1px solid #f1f5f9; border-radius: 0.5rem; overflow: hidden; }
    .pd-ingredient-row {
        display: flex; justify-content: space-between; padding: 0.5rem 0.75rem;
        font-size: 0.85rem; border-bottom: 1px solid #f1f5f9;
    }
    .pd-ingredient-row:last-child { border-bottom: none; }
    .pd-ingredient-row span:first-child { font-weight: 600; color: #334155; }
    .pd-ingredient-row span:last-child { color: #64748b; }

    .pd-notice {
        display: flex; gap: 0.85rem; padding: 1rem;
        background: #fffbeb; border: 1px solid #fde68a; border-radius: 0.75rem;
    }
    .pd-notice > i { color: #d97706; font-size: 1.25rem; margin-top: 2px; }
    .pd-notice strong { display: block; font-size: 0.85rem; color: #92400e; margin-bottom: 0.25rem; }
    .pd-notice p { margin: 0; font-size: 0.8rem; color: #78350f; line-height: 1.55; }

    .pd-trust {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem;
        padding-top: 0.25rem;
    }
    .pd-trust-item {
        text-align: center; font-size: 0.75rem; color: #64748b;
        padding: 0.65rem 0.35rem; background: #f8fafc; border-radius: 0.5rem;
    }
    .pd-trust-item i { display: block; font-size: 1.1rem; color: #1976d2; margin-bottom: 0.3rem; }

    @@media (max-width: 575px) {
        .pd-purchase-top { flex-direction: column; }
        .pd-badges { flex-direction: row; align-items: center; }
        .pd-cart-row { flex-direction: column; }
        .pd-trust { grid-template-columns: 1fr; }
    }

    .slider-images img:hover,
    .slider-images img.selected-item-slider {
        box-shadow: 0 2px 8px #60a5fa44;
        border-color: #2563eb !important;
        z-index: 2;
    }

    .horizontal-slider {
        position: relative;
        width: 100%;
        margin-top: 10px;
    }

    .slider-images {
        /* Remove flex-direction for horizontal */
    }

    .slider-images img {
        margin: 0 6px;
    }

    /* Card and shadow effects */
    .shadow-lg {
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        transition: box-shadow 0.3s ease;
    }

    .shadow-lg:hover {
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
    }

    /* Table styles */
    .table {
        --bs-table-bg: #ffffff;
        --bs-table-border-color: #e5e7eb;
        font-size: 0.9rem;
    }

    .table th,
    .table td {
        padding: 0.75rem 1rem;
        vertical-align: top;
        border-top: none;
    }

    .table td {
        color: #4b5563;
    }

    .table.table-borderless tbody tr {
        border-bottom: 1px solid #e5e7eb;
    }

    .table.table-borderless tbody tr:last-child {
        border-bottom: none;
    }

    /* Ingredient list */
    .ingredient-list {
        list-style: none;
        padding-left: 0;
        margin: 0;
        color: #2d3748;
        font-size: 0.85rem;
        line-height: 1.6;
    }

    .ingredient-list div {
        display: flex;
        justify-content: space-between;
        padding: 0.3rem 0;
        border-bottom: 1px dashed #e5e7eb;
    }

    .ingredient-list div:last-child {
        border-bottom: none;
    }

    .ingredient-list div span:first-child {
        font-weight: 600;
        color: #1a202c;
        margin-right: 1rem;
    }

    .ingredient-list div span:last-child {
        color: #4a5568;
        white-space: nowrap;
    }

    /* Quantity input */
    .quantity-input {
        transition: all 0.3s ease;
    }

    .quantity-input:hover {
        border-color: #60a5fa;
        box-shadow: 0 2px 8px rgba(96, 165, 250, 0.2);
    }

    /* Policy section */
    .border-top {
        border-top: 1px solid #e5e7eb !important;
    }

    .policy-item {
        transition: transform 0.3s ease;
    }

    .policy-item:hover {
        transform: translateY(-5px);
    }

    /* Container chung */
    .product-container {
        background: #ffffff;
        padding: 30px;
    }

    /* Sticky cho slider ảnh */
    .sticky-top {
        position: -webkit-sticky;
        position: sticky;
        top: 20px;
        max-height: calc(100vh - 40px);
        overflow-y: auto;
        z-index: 0;
    }

    /* Responsive styles for mobile */
    @@media (max-width: 991px) {
        .horizontal-slider {
            margin: 0 auto 1rem auto;
        }

        .col-lg-5,
        .col-lg-7 {
            min-width: 100%;
        }

        .sticky-top {
            position: relative;
            /* Tắt sticky trên mobile */
            top: 0;
            max-height: none;
        }

        .product-container {
            padding: 15px;
        }
    }
</style>

<script>
    let currentPosition = 0;
    const imageWidth = 74; // 60px img + 2*7px margin
    const totalImages = @Model.ProductImages?.Count();
    const visibleImages = 6;

    function moveUp() { // left
        if (currentPosition > 0) {
            currentPosition--;
            updateSlider();
        }
    }

    function moveDown() { // right
        if (currentPosition < totalImages - visibleImages) {
            currentPosition++;
            updateSlider();
        }
    }

    function imageClicked(src) {
        const mainImage = document.getElementById('mainImage');
        mainImage.src = src; // Cập nhật ảnh chính khi nhấp
        const sliderImages = document.getElementById('sliderImages').querySelectorAll('img');
        sliderImages.forEach(img => img.classList.remove('selected-item-slider'));
        const clickedImg = Array.from(sliderImages).find(img => img.src === src);
        if (clickedImg) clickedImg.classList.add('selected-item-slider');
    }

    function updateSlider() {
        const sliderImages = document.getElementById('sliderImages');
        sliderImages.style.transform = `translateX(${-imageWidth * currentPosition}px)`;
    }

    function decreaseQuantity() {
        const quantity = document.getElementById('quantity');
        if (parseInt(quantity.value) > 1) {
            quantity.value = (parseInt(quantity.value) - 1).toString();
        }
    }

    function increaseQuantity() {
        const quantity = document.getElementById('quantity');
        if (parseInt(quantity.value) < @Model.StockQuantity) {
            quantity.value = (parseInt(quantity.value) + 1).toString();
        }
    }

    // Khởi tạo ảnh đầu tiên
    document.addEventListener('DOMContentLoaded', () => {
        const firstImage = document.getElementById('sliderImages').querySelector('img');
        if (firstImage) imageClicked(firstImage.src);
    });
</script>
@if (TempData["ReviewError"] != null)
{
    <div class="alert alert-danger">@TempData["ReviewError"]</div>
}
@if (TempData["ReviewSuccess"] != null)
{
    <div class="alert alert-success">@TempData["ReviewSuccess"]</div>
}
@if (User.Identity.IsAuthenticated && userReview != null)
{
    <div class="card p-4 mb-4 mt-4 shadow-sm">
        <h5 class="mb-3">Sửa đánh giá của bạn</h5>
        <form asp-action="EditReview" asp-controller="Product" method="post" id="editReviewForm" onsubmit="return confirmSubmit(this, 'Bạn có chắc chắn muốn cập nhật đánh giá?', { confirmButtonText: 'Cập nhật' });">
            <input type="hidden" name="reviewId" value="@userReview.ReviewId" />
            <div class="mb-3">
                <label class="form-label">Chọn số sao</label>
                <div id="editStarRating" class="star-rating selectable">
                    @for (int i = 1; i <= 5; i++)
                    {
                        var selected = i <= (userReview.Rating ?? 0) ? "fa-solid fa-star text-warning" : "fa-regular fa-star text-secondary";
                        <i class="star @selected" data-value="@i"></i>
                    }
                </div>
                <input type="hidden" name="rating" id="editRatingInput" value="@userReview.Rating" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Nhận xét</label>
                <textarea name="comment" class="form-control" rows="3" required>@userReview.Comment</textarea>
            </div>
            <button type="submit" class="btn btn-warning">Cập nhật đánh giá</button>
        </form>
    </div>
}
else if (User.Identity.IsAuthenticated && canReview)
{
    <div class="card p-4 mb-4 mt-4 shadow-sm">
        <h5 class="mb-3">Đánh giá sản phẩm</h5>
        <form asp-action="AddReview" asp-controller="Product" method="post" id="reviewForm">
            <input type="hidden" name="productId" value="@Model.ProductId" />
            <div class="mb-3">
                <label class="form-label">Chọn số sao</label>
                <div id="starRating" class="star-rating selectable">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="star fa-regular fa-star text-secondary" data-value="@i"></i>
                    }
                </div>
                <input type="hidden" name="rating" id="ratingInput" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Nhận xét</label>
                <textarea name="comment" class="form-control" rows="3" required></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Gửi đánh giá</button>
        </form>
    </div>
}
else if (!User.Identity.IsAuthenticated)
{
    <div class="alert alert-warning mt-4">Vui lòng <a href="/Auth/Index">đăng nhập</a> để đánh giá sản phẩm.</div>
}

<!-- Danh sách đánh giá -->
<div class="mt-5" id="reviews-section">
    <h5 class="mb-3">Đánh giá của khách hàng</h5>
    @if (Model.Reviews != null && Model.Reviews.Any())
    {
        foreach (var review in Model.Reviews.OrderByDescending(r => r.ReviewDate))
        {
            <div class="review-item d-flex align-items-start gap-3 pb-3 mb-4 bg-white rounded-4 shadow-sm border position-relative" style="padding: 20px 24px;">
                <div class="avatar flex-shrink-0">
                    <img src="https://nhathuoclongchau.com.vn/estore-images/profile/v2/avatar-profile-large.svg" alt="avatar" style="width:48px;height:48px;border-radius:50%;object-fit:cover;" />
                </div>
                <div class="flex-grow-1">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        @{
                            string displayName = "Ẩn danh";
                            if (review.User != null)
                            {
                                if (!string.IsNullOrEmpty(review.User.UserName) && !review.User.UserName.Contains("@"))
                                {
                                    displayName = review.User.UserName;
                                }
                                else if (!string.IsNullOrEmpty(review.User.Email))
                                {
                                    displayName = review.User.Email.Split('@')[0];
                                }
                            }
                        }
                        <span class="fw-bold text-dark">@displayName</span>
                        <span class="ms-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= (review.Rating ?? 0))
                                {
                                    <i class="fa-solid fa-star text-warning"></i>
                                }
                                else
                                {
                                    <i class="fa-regular fa-star text-secondary"></i>
                                }
                            }
                        </span>
                        <span class="text-muted small ms-3">@review.ReviewDate?.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    <div class="text-dark" style="font-size:1.05rem;">@review.Comment</div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-muted">Chưa có đánh giá nào cho sản phẩm này.</div>
    }
</div>
