@section Scripts {
    <script>
        // Form đánh giá mới
        document.addEventListener('DOMContentLoaded', function () {
            function setupStarRating(starSelector, inputSelector) {
                const stars = document.querySelectorAll(starSelector);
                const ratingInput = document.querySelector(inputSelector);
                let selected = ratingInput && ratingInput.value ? parseInt(ratingInput.value) : 0;
                if (stars.length > 0) {
                    stars.forEach((star, idx) => {
                        star.addEventListener('mouseenter', function () {
                            highlightStars(idx + 1);
                        });
                        star.addEventListener('mouseleave', function () {
                            highlightStars(selected);
                        });
                        star.addEventListener('click', function () {
                            selected = idx + 1;
                            ratingInput.value = selected;
                            highlightStars(selected);
                        });
                    });
                    function highlightStars(count) {
                        stars.forEach((star, i) => {
                            if (i < count) {
                                star.classList.remove('fa-regular','text-secondary');
                                star.classList.add('fa-solid','text-warning','selected');
                            } else {
                                star.classList.remove('fa-solid','text-warning','selected');
                                star.classList.add('fa-regular','text-secondary');
                            }
                        });
                    }
                    highlightStars(selected);
                }
            }
            setupStarRating('#starRating .star', '#ratingInput');
            setupStarRating('#editStarRating .star', '#editRatingInput');

            var askBtn = document.getElementById('ask-product-btn');
            if (askBtn) {
                askBtn.onclick = function () {
                    // Mở popup chat
                    var popup = document.getElementById('chat-popup');
                    var fab = document.getElementById('chat-fab');
                    if (popup && fab) {
                        popup.style.display = 'block';
                        fab.style.display = 'none';
                    }
                    // Ping sản phẩm vào chat (ảnh, tên, mã)
                    if (window.addProductPingToChat) {
                        window.addProductPingToChat({
                            id: '@Model.ProductId',
                            name: `@Model.ProductName.Replace("'", "\'")` ,
                            image: '/images/products/@(Model.ProductImages?.FirstOrDefault(i => i.IsMain == true)?.ImageUrl ?? Model.ProductImages?.FirstOrDefault()?.ImageUrl ?? "vitamin_vien_sui_kudos_do.png")'
                        });
                    }
                };
            }
        });
    </script>
}