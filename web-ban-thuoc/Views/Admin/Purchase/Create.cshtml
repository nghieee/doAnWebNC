@model web_ban_thuoc.Models.CreatePurchaseOrderViewModel
@using web_ban_thuoc.Models
@{
    ViewData["Title"] = "Tạo đơn đặt hàng";
    Layout = "~/Views/Admin/_Layout.cshtml";
    var suppliers = (IEnumerable<Supplier>)ViewBag.Suppliers;
    var warehouses = (IEnumerable<Warehouse>)ViewBag.Warehouses;
    var products = (IEnumerable<Product>)ViewBag.Products;
    var stockByProduct = (Dictionary<int, int>)ViewBag.StockByProduct ?? new Dictionary<int, int>();
}

<div class="container-fluid py-3">
    <div class="card border-0 shadow-sm rounded-4 p-4">
        <h5 class="fw-bold mb-4">Đơn đặt hàng nhà cung cấp</h5>
        <form method="post" id="poForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Nhà cung cấp <span class="text-danger">*</span></label>
                    <select asp-for="SupplierId" id="supplierSelect" class="form-select" required>
                        <option value="">-- Chọn NCC trước --</option>
                        @foreach (var s in suppliers)
                        {
                            <option value="@s.SupplierId" selected="@(Model.SupplierId == s.SupplierId)">@s.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Kho nhận</label>
                    <select asp-for="WarehouseId" class="form-select" required>
                        @foreach (var w in warehouses)
                        {
                            <option value="@w.WarehouseId">@w.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Ngày dự kiến</label>
                    <input asp-for="ExpectedDate" type="date" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Ghi chú</label>
                    <input asp-for="Note" class="form-control" />
                </div>
            </div>

            <div id="productHint" class="alert alert-info py-2 small mb-3">
                <i class="fa fa-info-circle me-1"></i> Chọn <strong>Nhà cung cấp</strong> để hiển thị danh sách sản phẩm thuộc NCC đó.
            </div>

            <h6 class="fw-semibold mb-2">Chi tiết sản phẩm</h6>
            <div id="linesContainer">
                @for (int i = 0; i < Model.Lines.Count; i++)
                {
                    <div class="row g-2 mb-2 line-row">
                        <div class="col-md-5">
                            <input type="hidden" name="Lines[@i].ProductId" class="product-id-input" value="@(Model.Lines[i].ProductId > 0 ? Model.Lines[i].ProductId.ToString() : "")" />
                            <button type="button" class="btn btn-outline-secondary w-100 text-start d-flex align-items-center gap-2 product-picker-btn" disabled>
                                <span class="product-picker-label text-muted"><i class="fa fa-magnifying-glass me-1"></i> Chọn sản phẩm...</span>
                            </button>
                        </div>
                        <div class="col-md-3">
                            <input name="Lines[@i].QuantityOrdered" type="number" min="1" class="form-control" placeholder="SL đặt" required />
                        </div>
                        <div class="col-md-3">
                            <input name="Lines[@i].UnitCost" type="number" min="0" step="1000" class="form-control unit-cost-input" placeholder="Giá nhập" required />
                        </div>
                        <div class="col-md-1">
                            <button type="button" class="btn btn-outline-danger btn-sm remove-line"><i class="fa fa-trash"></i></button>
                        </div>
                    </div>
                }
            </div>
            <button type="button" class="btn btn-outline-secondary btn-sm mb-4" id="addLine" disabled><i class="fa fa-plus"></i> Thêm dòng</button>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Tạo đơn (Nháp)</button>
                <a href="/AdminPurchase" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>

<!-- Modal chọn sản phẩm: ảnh, tên, tồn kho khả dụng (lọc theo NCC đã chọn) -->
<div class="modal fade" id="poProductPickerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fa fa-boxes-stacked me-2"></i>Chọn sản phẩm</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body">
                <div class="input-group mb-3">
                    <span class="input-group-text"><i class="fa fa-magnifying-glass"></i></span>
                    <input type="text" class="form-control" id="poProductSearch" placeholder="Tìm theo tên hoặc SKU..." autocomplete="off" />
                </div>
                <div class="row g-2" id="poProductList"></div>
                <p class="text-muted text-center mb-0 d-none" id="poProductEmpty">Không có sản phẩm phù hợp.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let lineIndex = @Model.Lines.Count;
const allProducts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    products.Select(p => new {
        id = p.ProductId,
        name = p.ProductName,
        sku = p.Sku ?? "",
        supplierId = p.SupplierId,
        costPrice = p.CostPrice ?? 0,
        stock = stockByProduct.ContainsKey(p.ProductId) ? stockByProduct[p.ProductId] : 0,
        img = "/images/products/" + ((p.ProductImages.FirstOrDefault(i => i.IsMain == true) ?? p.ProductImages.FirstOrDefault())?.ImageUrl ?? "default.png")
    })));

const pickerModalEl = document.getElementById('poProductPickerModal');
const pickerModal = new bootstrap.Modal(pickerModalEl);
const pickerListEl = document.getElementById('poProductList');
const pickerSearchEl = document.getElementById('poProductSearch');
const pickerEmptyEl = document.getElementById('poProductEmpty');
let activeRow = null;

function getProductsForSupplier(supplierId) {
    if (!supplierId) return [];
    return allProducts.filter(p => p.supplierId == supplierId);
}

function productById(id) {
    return allProducts.find(p => p.id == id);
}

function setRowProduct(row, product) {
    const idInput = row.querySelector('.product-id-input');
    const label = row.querySelector('.product-picker-label');
    if (!product) {
        idInput.value = '';
        label.className = 'product-picker-label text-muted';
        label.innerHTML = '<i class="fa fa-magnifying-glass me-1"></i> Chọn sản phẩm...';
        return;
    }
    idInput.value = product.id;
    label.className = 'product-picker-label d-flex align-items-center gap-2 w-100';
    label.innerHTML = `<img src="${product.img}" alt="" class="rounded border" style="width:32px;height:32px;object-fit:cover;background:#f4f6fb;" />
        <span class="text-truncate"><span class="fw-semibold d-block text-truncate">${product.name}</span>
        <small class="text-muted">Tồn khả dụng: ${product.stock}${product.sku ? ' • SKU: ' + product.sku : ''}</small></span>`;
    const costInput = row.querySelector('.unit-cost-input');
    if (costInput && product.costPrice && product.costPrice != 0) costInput.value = product.costPrice;
}

function renderPickerList(list) {
    pickerListEl.innerHTML = list.map(p => `
        <div class="col-md-6 po-picker-item" data-id="${p.id}" data-search="${(p.name + ' ' + p.sku).toLowerCase()}">
            <div class="card h-100 border po-picker-card" role="button">
                <div class="card-body d-flex align-items-center gap-3 py-2">
                    <img src="${p.img}" alt="" class="rounded border" style="width:56px;height:56px;object-fit:cover;background:#f4f6fb;" />
                    <div class="flex-grow-1" style="min-width:0;">
                        <div class="fw-semibold text-truncate">${p.name}</div>
                        <div class="small text-muted">SKU: ${p.sku || '—'}</div>
                        <span class="badge ${p.stock <= 10 ? 'bg-danger' : 'bg-success'} mt-1">Tồn khả dụng: ${p.stock}</span>
                    </div>
                </div>
            </div>
        </div>`).join('');
    pickerEmptyEl.classList.toggle('d-none', list.length !== 0);
}

function openPickerFor(row) {
    const supplierId = document.getElementById('supplierSelect').value;
    if (!supplierId) return;
    activeRow = row;
    pickerSearchEl.value = '';
    renderPickerList(getProductsForSupplier(supplierId));
    pickerModal.show();
}

pickerListEl.addEventListener('click', e => {
    const item = e.target.closest('.po-picker-item');
    if (!item || !activeRow) return;
    setRowProduct(activeRow, productById(item.dataset.id));
    pickerModal.hide();
});

pickerSearchEl.addEventListener('input', function () {
    const q = this.value.trim().toLowerCase();
    let visible = 0;
    pickerListEl.querySelectorAll('.po-picker-item').forEach(item => {
        const match = item.dataset.search.indexOf(q) !== -1;
        item.classList.toggle('d-none', !match);
        if (match) visible++;
    });
    pickerEmptyEl.classList.toggle('d-none', visible !== 0);
});

pickerModalEl.addEventListener('shown.bs.modal', () => pickerSearchEl.focus());

function refreshLinesState() {
    const supplierId = document.getElementById('supplierSelect').value;
    const list = getProductsForSupplier(supplierId);
    const addBtn = document.getElementById('addLine');
    const hint = document.getElementById('productHint');

    addBtn.disabled = !supplierId || list.length === 0;
    document.querySelectorAll('.product-picker-btn').forEach(b => b.disabled = !supplierId || list.length === 0);

    if (!supplierId) {
        hint.className = 'alert alert-info py-2 small mb-3';
        hint.innerHTML = '<i class="fa fa-info-circle me-1"></i> Chọn <strong>Nhà cung cấp</strong> để hiển thị danh sách sản phẩm.';
    } else if (list.length === 0) {
        hint.className = 'alert alert-warning py-2 small mb-3';
        hint.innerHTML = '<i class="fa fa-triangle-exclamation me-1"></i> NCC này chưa có sản phẩm nào. Gán NCC tại <a href="/AdminProduct">Quản lý sản phẩm</a>.';
    } else {
        hint.className = 'alert alert-success py-2 small mb-3';
        hint.innerHTML = `<i class="fa fa-check-circle me-1"></i> ${list.length} sản phẩm thuộc NCC đã chọn.`;
    }
}

document.getElementById('supplierSelect').addEventListener('change', () => {
    document.querySelectorAll('.line-row').forEach(row => {
        setRowProduct(row, null);
        const costInput = row.querySelector('.unit-cost-input');
        if (costInput) costInput.value = '';
    });
    refreshLinesState();
});

document.getElementById('addLine').addEventListener('click', () => {
    const supplierId = document.getElementById('supplierSelect').value;
    if (!supplierId) return;
    const html = `<div class="row g-2 mb-2 line-row">
        <div class="col-md-5">
            <input type="hidden" name="Lines[${lineIndex}].ProductId" class="product-id-input" />
            <button type="button" class="btn btn-outline-secondary w-100 text-start d-flex align-items-center gap-2 product-picker-btn">
                <span class="product-picker-label text-muted"><i class="fa fa-magnifying-glass me-1"></i> Chọn sản phẩm...</span>
            </button>
        </div>
        <div class="col-md-3"><input name="Lines[${lineIndex}].QuantityOrdered" type="number" min="1" class="form-control" placeholder="SL đặt" required /></div>
        <div class="col-md-3"><input name="Lines[${lineIndex}].UnitCost" type="number" min="0" step="1000" class="form-control unit-cost-input" placeholder="Giá nhập" required /></div>
        <div class="col-md-1"><button type="button" class="btn btn-outline-danger btn-sm remove-line"><i class="fa fa-trash"></i></button></div>
    </div>`;
    document.getElementById('linesContainer').insertAdjacentHTML('beforeend', html);
    lineIndex++;
});

document.getElementById('linesContainer').addEventListener('click', e => {
    const pickerBtn = e.target.closest('.product-picker-btn');
    if (pickerBtn) {
        openPickerFor(pickerBtn.closest('.line-row'));
        return;
    }
    if (e.target.closest('.remove-line')) {
        const rows = document.querySelectorAll('.line-row');
        if (rows.length > 1) e.target.closest('.line-row').remove();
    }
});

document.addEventListener('DOMContentLoaded', () => {
    refreshLinesState();
    // Khôi phục sản phẩm đã chọn (khi form trả lại do lỗi validate)
    document.querySelectorAll('.line-row').forEach(row => {
        const id = row.querySelector('.product-id-input')?.value;
        if (id) setRowProduct(row, productById(id));
    });
});
</script>
}
