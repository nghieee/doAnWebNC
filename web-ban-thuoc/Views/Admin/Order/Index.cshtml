@model List<web_ban_thuoc.Models.Order>
@using web_ban_thuoc.Models
@{
    Layout = "~/Views/Admin/_Layout.cshtml";
    ViewData["Title"] = "Quản lý đơn hàng";
    var statusList = OrderStatuses.AdminManageable.ToList();
}
<div class="container-fluid">
    <div class="alert alert-info border-0 shadow-sm rounded-4 mb-3">
        <i class="fa fa-circle-info me-2"></i>
        <strong>Luồng xử lý đơn bán:</strong> Chờ xác nhận → <strong>Đã xác nhận</strong> (tự xuất kho FEFO) → Đóng gói → Giao → Hoàn tất.
        Hủy đơn sau khi xác nhận sẽ hoàn tồn kho.
    </div>
    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-body p-4">
            <form method="get" class="row g-3 mb-4 align-items-end">
                @Html.AntiForgeryToken()
                <div class="col-md-4">
                    <input type="text" name="search" class="form-control" placeholder="Tìm theo tên, SĐT, mã đơn..." value="@ViewBag.Search" />
                </div>
                <div class="col-md-3">
                    <select name="status" class="form-select">
                        @{
                            var allStatus = new List<string> { "Tất cả" };
                            allStatus.AddRange(OrderStatuses.All);
                        }
                        @foreach (var s in allStatus)
                        {
                            var isSelected = Convert.ToString(ViewBag.Status) == s || (ViewBag.Status == null && s == "Tất cả");
                            if (isSelected)
                            {
                                <option value="@s" selected>@s</option>
                            }
                            else
                            {
                                <option value="@s">@s</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100"><i class="fa fa-filter me-1 align-self-center"></i>Lọc</button>
                    <a href="/AdminOrder" class="btn btn-outline-secondary w-100">Xóa lọc</a>
                </div>
            </form>
            <div class="accordion" id="ordersAccordion">
                @foreach (var order in Model)
                {
                    var collapseId = $"collapse_order_{order.OrderId}";
                    var headingId = $"heading_order_{order.OrderId}";
                    <div class="accordion-item mb-2 border-0 shadow-sm rounded-3">
                        <h2 class="accordion-header" id="@headingId">
                            <button class="accordion-button collapsed bg-white rounded-3" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                                <div class="d-flex justify-content-between align-items-center w-100 me-3">
                                    <div class="d-flex align-items-center">
                                        <div class="me-3">
                                            <div class="fw-bold text-dark">Đơn hàng #@order.OrderId</div>
                                            <div class="small text-muted">@order.OrderDate?.ToString("dd/MM/yyyy HH:mm")</div>
                                        </div>
                                    </div>
                                    <div class="text-end">
                                        <div class="fw-bold text-primary">@order.TotalAmount?.ToString("N0")đ</div>
                                        <div class="small">
                                            <span class="badge @GetStatusBadgeClass(order.Status)">@order.Status</span>
                                        </div>
                                    </div>
                                </div>
                            </button>
                        </h2>
                        <div id="@collapseId" class="accordion-collapse collapse" aria-labelledby="@headingId" data-bs-parent="#ordersAccordion">
                            <div class="accordion-body pt-0">
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <div class="small text-muted mb-1">Người nhận:</div>
                                        <div class="fw-semibold">@order.FullName</div>
                                        <div class="small text-muted">@order.Phone</div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="small text-muted mb-1">Địa chỉ:</div>
                                        <div class="small">@order.ShippingAddress</div>
                                    </div>
                                </div>
                                <div class="border-top pt-3">
                                    <h6 class="fw-semibold mb-3">Sản phẩm đã đặt:</h6>
                                    @foreach (var item in order.OrderItems)
                                    {
                                        <div class="d-flex align-items-center mb-3 p-3 bg-light rounded-3">
                                            <img src="/images/products/@(item.Product?.ProductImages?.FirstOrDefault(i => i.IsMain == true)?.ImageUrl ?? item.Product?.ProductImages?.FirstOrDefault()?.ImageUrl ?? "sanpham.png")" alt="@item.Product?.ProductName" class="rounded me-3" style="width: 60px; height: 60px; object-fit: cover;">
                                            <div class="flex-grow-1">
                                                <div class="fw-semibold">@item.Product?.ProductName</div>
                                                <div class="small text-muted">Số lượng: @item.Quantity</div>
                                            </div>
                                            <div class="text-end">
                                                <div class="fw-semibold">@item.Price.ToString("N0")đ</div>
                                                <div class="small text-muted">@((item.Price * item.Quantity).ToString("N0"))đ</div>
                                            </div>
                                        </div>
                                    }
                                </div>
                                @if (order.StatusHistories?.Any() == true)
                                {
                                    <div class="border-top pt-3 mb-3">
                                        <h6 class="fw-semibold mb-2">Lịch sử trạng thái</h6>
                                        <ul class="list-unstyled small mb-0">
                                            @foreach (var h in order.StatusHistories.OrderBy(x => x.ChangedAt))
                                            {
                                                <li class="mb-1">
                                                    <i class="fa fa-clock text-muted me-1"></i>
                                                    @h.ChangedAt.ToString("dd/MM/yyyy HH:mm") —
                                                    @(h.FromStatus != null ? $"{h.FromStatus} → " : "")<strong>@h.ToStatus</strong>
                                                    @if (!string.IsNullOrEmpty(h.Note)) { <span class="text-muted">(@h.Note)</span> }
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                }
                                <div class="border-top pt-3 mb-3">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="fw-bold">Tổng cộng:</span>
                                        <span class="fw-bold text-primary fs-5">@order.TotalAmount?.ToString("N0")đ</span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center mt-2">
                                        <span class="small text-muted">Trạng thái thanh toán:</span>
                                        <span class="badge bg-secondary">@order.PaymentStatus</span>
                                    </div>
                                </div>
                                <div class="border-top pt-3 mb-3">
                                    <h6 class="fw-semibold mb-2"><i class="fa fa-truck me-1"></i>Vận chuyển</h6>
                                    @if (order.Shipment != null)
                                    {
                                        var trackUrl = ShippingCarriers.GetTrackingUrl(order.Shipment.Carrier, order.Shipment.TrackingCode);
                                        <div class="small">
                                            <div><strong>@order.Shipment.Carrier</strong> — Mã: <code>@order.Shipment.TrackingCode</code></div>
                                            @if (trackUrl != null) { <a href="@trackUrl" target="_blank" class="small">Theo dõi vận đơn</a> }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="small text-muted mb-2">Chưa có mã vận đơn</div>
                                    }
                                    <div class="row g-2 mt-1 shipment-form" data-order-id="@order.OrderId">
                                        <div class="col-md-3">
                                            <select class="form-select form-select-sm ship-carrier">
                                                @foreach (var c in ShippingCarriers.All)
                                                {
                                                    <option value="@c.Code" selected="@(order.Shipment?.Carrier == c.Code)">@c.Name</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-4">
                                            <input type="text" class="form-control form-control-sm ship-tracking" placeholder="Mã vận đơn" value="@order.Shipment?.TrackingCode" />
                                        </div>
                                        <div class="col-md-2">
                                            <input type="number" class="form-control form-control-sm ship-fee" placeholder="Phí ship" value="@order.Shipment?.ShippingFee" />
                                        </div>
                                        <div class="col-md-3">
                                            <button type="button" class="btn btn-sm btn-outline-primary w-100 save-shipment-btn">Lưu vận đơn</button>
                                        </div>
                                    </div>
                                </div>
                                @if (order.Status != OrderStatuses.Cancelled && order.Status != OrderStatuses.Delivered)
                                {
                                    <div class="mt-3 d-flex gap-2">
                                        <select class="form-select form-select-sm status-select" data-order-id="@order.OrderId" style="width: 180px;">
                                            @foreach (var s in statusList)
                                            {
                                                if (OrderStatuses.CanTransition(order.Status ?? "", s) || s == order.Status)
                                                {
                                                    if (order.Status == s)
                                                    {
                                                        <option value="@s" selected>@s</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@s">@s</option>
                                                    }
                                                }
                                            }
                                            @if (OrderStatuses.CanTransition(order.Status ?? "", OrderStatuses.Cancelled))
                                            {
                                                <option value="@OrderStatuses.Cancelled">@OrderStatuses.Cancelled</option>
                                            }
                                        </select>
                                        <button type="button" class="btn btn-sm btn-success change-status-btn" data-order-id="@order.OrderId">Cập nhật</button>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
            <partial name="_AdminPagination" />
        </div>
    </div>
</div>

@section Scripts {
<script>
document.querySelectorAll('.save-shipment-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        const form = this.closest('.shipment-form');
        const orderId = form.dataset.orderId;
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        const body = new URLSearchParams({
            orderId, __RequestVerificationToken: token || '',
            carrier: form.querySelector('.ship-carrier').value,
            trackingCode: form.querySelector('.ship-tracking').value,
            shippingFee: form.querySelector('.ship-fee').value || ''
        });
        fetch('@Url.Action("SaveShipment", "AdminOrder")', { method: 'POST', body })
            .then(r => r.json()).then(d => { showAlert(d.message, { icon: d.success ? 'success' : 'error' }).then(() => { if (d.success) location.reload(); }); });
    });
});

document.querySelectorAll('.change-status-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        const orderId = this.dataset.orderId;
        const select = document.querySelector(`.status-select[data-order-id="${orderId}"]`);
        const newStatus = select.value;
        if (newStatus === '@OrderStatuses.Shipped') {
            const tracking = document.querySelector(`.shipment-form[data-order-id="${orderId}"] .ship-tracking`)?.value?.trim();
            if (!tracking) {
                showAlert('Vui lòng nhập và lưu mã vận đơn trước khi chuyển sang Đang giao.', { icon: 'warning' });
                return;
            }
        }
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        fetch('@Url.Action("ChangeStatus", "AdminOrder")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': token
            },
            body: `orderId=${orderId}&newStatus=${encodeURIComponent(newStatus)}&__RequestVerificationToken=${encodeURIComponent(token || '')}`
        })
        .then(r => r.json())
        .then(data => {
            showAlert(data.message, { icon: data.success ? 'success' : 'error' }).then(() => { if (data.success) location.reload(); });
        });
    });
});
</script>
}

@functions {
    string GetStatusBadgeClass(string? status) => status switch
    {
        OrderStatuses.PendingPayment => "bg-secondary text-white",
        OrderStatuses.PendingConfirmation => "bg-warning text-dark",
        OrderStatuses.Confirmed => "bg-info text-white",
        OrderStatuses.Packing => "bg-primary text-white",
        OrderStatuses.Shipped => "bg-primary text-white",
        OrderStatuses.Delivered => "bg-success text-white",
        OrderStatuses.Cancelled => "bg-danger text-white",
        _ => "bg-secondary text-white"
    };
}
