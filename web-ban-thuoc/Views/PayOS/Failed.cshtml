@model web_ban_thuoc.Models.Order
@{
    ViewData["Title"] = "Thanh toán thất bại";
}

@section Styles {
    <link href="~/css/payos.css" rel="stylesheet" />
}

<div class="payos-page">
    <div class="payos-card">
        <div class="payos-card__body">
            <div class="payos-result">
                <div class="payos-result__icon payos-result__icon--danger">
                    <i class="fas fa-xmark"></i>
                </div>
                <h1>Thanh toán thất bại</h1>
                <p class="payos-result__sub">
                    Rất tiếc, giao dịch của bạn chưa được thực hiện thành công.
                </p>

                <div class="payos-result__recap">
                    <div class="payos-info-row">
                        <span class="label">Mã đơn hàng</span>
                        <span class="value">#@Model?.OrderId</span>
                    </div>
                    <div class="payos-info-row">
                        <span class="label">Tổng tiền</span>
                        <span class="value">@Model?.TotalAmount?.ToString("N0") VNĐ</span>
                    </div>
                    <div class="payos-info-row">
                        <span class="label">Trạng thái</span>
                        <span class="value">
                            <span class="payos-badge payos-badge--danger"><i class="fas fa-xmark"></i> Thất bại</span>
                        </span>
                    </div>
                </div>

                <div class="payos-result__actions">
                    @if (Model != null)
                    {
                        <a href="@Url.Action("CreatePayment", "PayOS", new { orderId = Model.OrderId })" class="payos-btn payos-btn--primary">
                            <i class="fas fa-rotate-right"></i> Thử lại thanh toán
                        </a>
                    }
                    <a href="/" class="payos-btn payos-btn--ghost"><i class="fas fa-home"></i> Về trang chủ</a>
                </div>

                <div class="payos-help">
                    <i class="fas fa-headset"></i>
                    <div>
                        Cần hỗ trợ? Gọi hotline
                        <a href="tel:18006928" class="fw-semibold">1800 6928</a> (miễn phí).
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
